{{ 'tailwind.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-card.js' | asset_url }}" defer="defer"></script>

<div class="mx-auto max-w-[1280px] px-[16px] py-[40px] sm:px-[24px] lg:px-[32px]">
  {%- if section.settings.heading != blank -%}
    <h2 class="mb-[24px] text-[24px] leading-[32px] font-bold text-gray-900">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="flex flex-wrap gap-[24px]">
    {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
      {%- render 'product-card', card_product: product -%}
    {%- else -%}
      {%- for product in collections.all.products limit: section.settings.products_to_show -%}
        {%- render 'product-card', card_product: product -%}
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Product card grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Product card grid"
    }
  ]
}
{% endschema %}
